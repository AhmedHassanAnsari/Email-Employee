# Model (Gemini via OpenAI Agents SDK)
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash-lite

# Postgres (app-owned `emails` table). Note the +asyncpg scheme.
POSTGRES_USER=email
POSTGRES_PASSWORD=email
POSTGRES_DB=email
DATABASE_URL=postgresql+asyncpg://email:email@localhost:5432/email

# Google OAuth (WE own consent + refresh tokens; external-provider mode).
# Same client credentials workspace-mcp uses (it also reads GOOGLE_OAUTH_CLIENT_*).
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must be registered as an authorized redirect URI in Google Cloud.
OAUTH_REDIRECT_URI=http://localhost:8001/oauth/google/callback
# Fernet key encrypting refresh tokens at rest. Generate with:
#   uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=generate-a-fernet-key

# Gmail MCP (taylorwilsdon/google_workspace_mcp), streamable-http,
# external-provider mode: EXTERNAL_OAUTH21_PROVIDER=true MCP_ENABLE_OAUTH21=true
GMAIL_MCP_URL=http://127.0.0.1:8000/mcp

# Agent service
AGENT_API_BASE=http://127.0.0.1:8001

# Poller
MONITOR_POLL_SECONDS=30
INBOX_DIR=inbox

# WhatsApp (Twilio sandbox). from/to must include the "whatsapp:" prefix.
account_sid=AC...
auth_token=your-twilio-token
from=whatsapp:+14155238886
to=whatsapp:+10000000000

# Observability (optional)
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://cloud.langfuse.com
